# Rockpool local development environment
# Copy to development.env and fill in your secrets:
#   cp development.env.example development.env
#
# See doc/EDD/003_Caddy_Reverse_Proxy.md appendix for GitHub OAuth setup.

# Runtime: "podman" (default) or "stub" (no real workspaces)
RUNTIME=podman
SPA_PROXY_URL=http://localhost:5173

# Basic auth (used when GitHub OAuth is not configured)
CADDY_USERNAME=admin
CADDY_PASSWORD=admin

# Client (Vite injects VITE_-prefixed vars at build/dev time)
VITE_IDE_URL=http://localhost:8081
VITE_PREVIEW_URL=http://localhost:8082

# GitHub OAuth
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
