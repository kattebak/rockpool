# CI environment — GitHub Actions
# Used with: ENV_FILE=ci.env podman compose up -d

# Environment
NODE_ENV=test

# Runtime: stub (no real VMs in CI)
RUNTIME=stub

# Server
PORT=9163
SRV0_PORT=9080
SRV1_PORT=9081
SRV2_PORT=9082
DB_PATH=/tmp/rockpool-ci.db
SPA_ROOT=packages/client/dist

# Caddy
CADDY_ADMIN_PORT=9019
CADDY_ADMIN_URL=http://localhost:9019
CADDY_USERNAME=test
CADDY_PASSWORD=test

# Queue (ElasticMQ on test port)
QUEUE_ENDPOINT=http://localhost:9424
QUEUE_URL=http://localhost:9424/000000000000/workspace-jobs

# SSH keys (for stub runtime, not actually used)
SSH_KEY_PATH=images/ssh/rockpool_ed25519

# E2E helper URLs
DASHBOARD_URL=http://localhost:9080
API_URL=http://localhost:9080/api
