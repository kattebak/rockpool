{
	"name": "rockpool",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"preinstall": "make ${CI:+ci} && echo 'Build complete'",
		"test": "npm run test --workspaces --if-present",
		"lint": "biome check .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"fix": "biome check --fix . && tsp format typespec/**/*.tsp",
		"check": "tsgo --noEmit",
		"check:tsc": "tsc --noEmit",
		"mvp:build-image": "npm-scripts/mvp-build-image.sh",
		"mvp:start-vm": "npm-scripts/mvp-start-vm.sh",
		"mvp:setup-vm": "npm-scripts/mvp-setup-vm.sh",
		"mvp:verify": "npm-scripts/mvp-verify.sh",
		"mvp:caddy:bootstrap": "npm-scripts/caddy-bootstrap.sh",
		"mvp:caddy:add-route": "npm-scripts/caddy-add-workspace-route.sh",
		"mvp:caddy:remove-route": "npm-scripts/caddy-remove-workspace-route.sh",
		"dev": "podman compose up",
		"prestart": "npm-scripts/preflight.sh",
		"start": "npm-scripts/start.sh",
		"stop": "npm-scripts/stop.sh",
		"dev:stop": "podman compose down",
		"dev:status": "podman compose ps",
		"dev:logs": "podman compose logs -f",
		"prestart:production": "set -a && . ./production.env && npm run build -w packages/client",
		"start:production": "ENV_FILE=production.env ELASTICMQ_CONF=elasticmq.production.conf podman compose -f compose.yaml up -d",
		"stop:production": "podman compose down",
		"test:e2e": "npx playwright test --config e2e/playwright.config.ts",
		"test:e2e:headless": "ENV_FILE=test.env ELASTICMQ_CONF=elasticmq.test.conf node --env-file=test.env node_modules/.bin/playwright test --config e2e/playwright.config.ts",
		"test:e2e:ci": "ENV_FILE=ci.env ELASTICMQ_CONF=elasticmq.test.conf node --env-file=ci.env node_modules/.bin/playwright test --config e2e/playwright.config.ts",
		"test:e2e:podman": "E2E_PROFILE=podman ENV_FILE=podman-test.env ELASTICMQ_CONF=elasticmq.test.conf node --env-file=podman-test.env node_modules/.bin/playwright test --config e2e/playwright.config.ts",
		"test:e2e:rootvm": "E2E_PROFILE=rootvm ENV_FILE=rootvm-test.env node --env-file=rootvm-test.env node_modules/.bin/playwright test --config e2e/playwright.config.ts",
		"test:e2e:smoke": "npx playwright test --config e2e/playwright.config.ts tests/01-smoke.spec.ts",
		"test:e2e:lifecycle": "npx playwright test --config e2e/playwright.config.ts tests/02-workspace-lifecycle.spec.ts",
		"test:e2e:ide": "npx playwright test --config e2e/playwright.config.ts tests/03-ide-loading.spec.ts",
		"start:vm": "npm-scripts/start-root-vm.sh",
		"stop:vm": "npm-scripts/stop-root-vm.sh",
		"ssh:vm": "npm-scripts/ssh-root-vm.sh",
		"vm:logs": "npm-scripts/vm-logs.sh",
		"logs": "podman compose logs -f"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@hey-api/openapi-ts": "^0.92.4",
		"@kattebak/typespec-drizzle-orm-generator": "^3.6.0",
		"@kattebak/typespec-enum-emitter": "^1.2.2",
		"@kattebak/typespec-zod-emitter": "^1.3.0",
		"@playwright/test": "^1.58.2",
		"@rockpool/db-schema": "file:build/db-schema",
		"@rockpool/enums": "file:build/enums",
		"@rockpool/openapi": "file:build/openapi",
		"@rockpool/sdk": "file:build/sdk",
		"@rockpool/validators": "file:build/validators",
		"@typescript/native-preview": "^7.0.0-dev.20260221.1",
		"@typespec/compiler": "^1.9.0",
		"@typespec/http": "^1.9.0",
		"@typespec/openapi3": "^1.9.0",
		"@typespec/rest": "^0.79.0",
		"drizzle-orm": "1.0.0-beta.15-859cf75",
		"short-uuid": "^5.2.0",
		"tsx": "^4.19.3",
		"typescript": "*"
	},
	"overrides": {
		"drizzle-orm": "1.0.0-beta.15-859cf75"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
