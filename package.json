{
	"name": "rockpool",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"preinstall": "make ci && echo 'Build complete'",
		"test": "npm run test --workspaces --if-present",
		"lint": "biome check .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"fix": "biome check --fix . && tsp format typespec/**/*.tsp",
		"check": "tsgo --noEmit",
		"start:test": "make .stamps/rockpool-workspace-container && VITE_IDE_URL=http://localhost:9081 VITE_PREVIEW_URL=http://localhost:9082 ROCKPOOL_CONFIG=rockpool.test.config.json npm run build -w packages/client && SRV0_PORT=9080 SRV1_PORT=9081 SRV2_PORT=9082 PORT=9163 CADDY_ADMIN_PORT=9019 QUEUE_PORT=9324 DB_PATH=/opt/rockpool/e2e.db ROCKPOOL_CONFIG=rockpool.test.config.json npm-scripts/podman.sh up -d",
		"stop:test": "npm-scripts/podman.sh down",
		"logs:test": "npm-scripts/podman.sh logs -f",
		"start:dev": "make .stamps/rockpool-workspace-container && SPA_PROXY_URL=http://control-plane:5173 NODE_WATCH=1 npm-scripts/podman.sh up -d",
		"stop:dev": "npm-scripts/podman.sh down",
		"logs:dev": "npm-scripts/podman.sh logs -f",
		"pretest:e2e:headless": "npm run start:test",
		"test:e2e:headless": "SRV0_PORT=9080 SRV1_PORT=9081 QUEUE_PORT=9324 ROCKPOOL_CONFIG=rockpool.test.config.json node_modules/.bin/playwright test --config e2e/playwright.config.ts",
		"start:tunnel": "make .stamps/rockpool-workspace-container && npm run build -w packages/client && npm-scripts/podman.sh --profile tunnel up -d",
		"stop:tunnel": "npm-scripts/podman.sh --profile tunnel down",
		"vm": "npm-scripts/root-vm.sh"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@hey-api/openapi-ts": "^0.92.4",
		"@kattebak/typespec-drizzle-orm-generator": "^3.6.0",
		"@kattebak/typespec-enum-emitter": "^1.2.2",
		"@kattebak/typespec-zod-emitter": "^1.3.0",
		"@playwright/test": "^1.58.2",
		"@rockpool/db-schema": "file:build/db-schema",
		"@rockpool/enums": "file:build/enums",
		"@rockpool/openapi": "file:build/openapi",
		"@rockpool/sdk": "file:build/sdk",
		"@rockpool/validators": "file:build/validators",
		"@typescript/native-preview": "^7.0.0-dev.20260221.1",
		"@typespec/compiler": "^1.9.0",
		"@typespec/http": "^1.9.0",
		"@typespec/openapi3": "^1.9.0",
		"@typespec/rest": "^0.79.0",
		"drizzle-orm": "1.0.0-beta.15-859cf75",
		"short-uuid": "^5.2.0",
		"tsx": "^4.19.3",
		"typescript": "*"
	},
	"overrides": {
		"drizzle-orm": "1.0.0-beta.15-859cf75"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
