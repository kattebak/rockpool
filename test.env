# E2E test environment — real stack, separate ports, ephemeral DB
# Loaded by npm scripts via: node --env-file=test.env
# Also loaded by compose via: ENV_FILE=test.env podman compose up -d

# Server
PORT=9163
SRV0_PORT=9080
SRV1_PORT=9081
SRV2_PORT=9082
VITE_IDE_URL=http://localhost:9081
VITE_PREVIEW_URL=http://localhost:9082
DB_PATH=/opt/rockpool/e2e.db
SPA_ROOT=packages/client/dist

# Caddy (CADDY_ADMIN_URL is set by compose overlay, not here)
CADDY_ADMIN_PORT=9019
CADDY_USERNAME=test
CADDY_PASSWORD=test

# Queue (ElasticMQ runs inside control-plane container)
QUEUE_ENDPOINT=http://localhost:9324
QUEUE_URL=http://localhost:9324/000000000000/workspace-jobs

# Runtime — podman (container-based workspaces)
# Override with RUNTIME=stub in npm scripts for CI
# SSH_KEY_PATH is used for Root VM SSH access only
SSH_KEY_PATH=images/ssh/rockpool_ed25519

# E2E helper URLs (resolved through Caddy, not direct)
DASHBOARD_URL=http://localhost:9080
API_URL=http://localhost:9080/api
